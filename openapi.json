{
  "openapi": "3.0.0",
  "info": {
    "title": "MCP Config Auto Generator",
    "version": "1.0.0"
  },
  "paths": {
    "/api/endpoint": {
      "get": {
        "summary": "MCP Config Auto Generation",
        "description": "This endpoint automatically generates MCP config based on swagger/openapi JSON.",
        "operationId": "generateMcConfig",
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  $ref: "#/components/schemas/generatedConfig" 
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string" 
                    }
                  },
                  "required": [
                    "error" 
                  ]
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "generatedConfig": {
        "$ref": "#/components/responses/generatedConfig"
      }
    }
  },
  "securityDefinitions": {
    "apiKeyAuth": {
      "type": "apiKey", 
      "name": "apiKey", 
      "description": "API Key",
      "in": "header"
    }
  },
  "security": [
    { "apiKeyAuth": [] }
  ]
}